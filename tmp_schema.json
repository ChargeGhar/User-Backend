  /api/admin/analytics/rentals-over-time:
    get:
      operationId: api_admin_analytics_rentals_over_time_retrieve
      description: "\n        Get rental statistics over time for chart visualization.\n\
        \        \n        **Features**:\n        - Aggregate by daily, weekly, or\
        \ monthly periods\n        - Filter by rental status\n        - Get breakdown\
        \ by status (completed, active, pending, cancelled, overdue)\n        - Summary\
        \ statistics (average, peak period)\n        - Ready-to-use chart data format\n\
        \        \n        **Use Cases**:\n        - Dashboard charts showing rental\
        \ trends\n        - Performance monitoring\n        - Business analytics\n\
        \        "
      summary: Rentals Over Time Analytics
      parameters:
      - in: query
        name: end_date
        schema:
          type: string
          format: date
        description: 'End date (YYYY-MM-DD). Default: today'
      - in: query
        name: period
        schema:
          type: string
          enum:
          - daily
          - monthly
          - weekly
        description: Aggregation period for data grouping
        required: true
      - in: query
        name: start_date
        schema:
          type: string
          format: date
        description: 'Start date (YYYY-MM-DD). Default: 30 days ago'
      - in: query
        name: status
        schema:
          type: string
          enum:
          - ACTIVE
          - CANCELLED
          - COMPLETED
          - OVERDUE
          - PENDING
        description: Filter by specific rental status
      tags:
      - Admin - Analytics
      security:
      - cookieAuth: []
      - basicAuth: []
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/RentalsOverTimeResponse'
          description: ''
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BaseResponse'
          description: ''
  /api/admin/analytics/revenue-over-time:
    get:
      operationId: api_admin_analytics_revenue_over_time_retrieve
      description: "\n        Get revenue statistics over time for chart visualization.\n\
        \        \n        **Features**:\n        - Aggregate by daily, weekly, or\
        \ monthly periods\n        - Filter by transaction type\n        - Get breakdown\
        \ by revenue source (rentals, top-ups, fines)\n        - Summary statistics\
        \ (average, peak period, growth rate)\n        - Ready-to-use chart data format\n\
        \        \n        **Revenue Sources**:\n        - Rental revenue (base rental\
        \ charges)\n        - Rental due revenue (overdue payments)\n        - Top-up\
        \ revenue (wallet recharges)\n        - Fine revenue (penalties)\n       \
        \ \n        **Use Cases**:\n        - Financial dashboard charts\n       \
        \ - Revenue trend analysis\n        - Business performance monitoring\n  \
        \      "
      summary: Revenue Over Time Analytics
      parameters:
      - in: query
        name: end_date
        schema:
          type: string
          format: date
        description: 'End date (YYYY-MM-DD). Default: today'
      - in: query
        name: period
        schema:
          type: string
          enum:
          - daily
          - monthly
          - weekly
        description: Aggregation period for data grouping
        required: true
      - in: query
        name: start_date
        schema:
          type: string
          format: date
        description: 'Start date (YYYY-MM-DD). Default: 180 days ago'
      - in: query
        name: transaction_type
        schema:
          type: string
          enum:
          - FINE
          - REFUND
          - RENTAL
          - RENTAL_DUE
          - TOPUP
