    CreateLateFeeConfigurationRequest:
      type: object
      description: Serializer for creating a new late fee configuration
      properties:
        name:
          type: string
          minLength: 1
          description: Clear name for this fee setting (e.g., 'Standard Late Fee')
          maxLength: 100
        fee_type:
          allOf:
          - $ref: '#/components/schemas/FeeTypeEnum'
          default: MULTIPLIER
          description: |-
            Fee calculation method: MULTIPLIER, FLAT_RATE, or COMPOUND

            * `MULTIPLIER` - Multiplier (e.g., 2x normal rate)
            * `FLAT_RATE` - Flat rate per hour
            * `COMPOUND` - Compound (multiplier + flat rate)
        multiplier:
          type: string
          format: decimal
          pattern: ^-?\d{0,3}(?:\.\d{0,2})?$
          default: '2.00'
          description: Multiplier for MULTIPLIER or COMPOUND types (e.g., 2.0 for
            2x rate)
        flat_rate_per_hour:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          default: '0.00'
          description: Flat rate per overdue hour (NPR) for FLAT_RATE or COMPOUND
            types
        grace_period_minutes:
          type: integer
          minimum: 0
          default: 0
          description: Minutes before late charges start (0 = immediate)
        max_daily_rate:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          nullable: true
          description: Maximum late fee per day (NPR) - leave empty for no limit
        is_active:
          type: boolean
          default: true
          description: Whether this configuration is currently active
        applicable_package_types:
          type: array
          items:
            type: string
            minLength: 1
          description: Limit to specific package types (empty = all packages)
        metadata:
          description: Additional metadata for this configuration
      required:
      - name
