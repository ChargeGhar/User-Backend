    PatchedChangeVendorTypeRequest:
      type: object
      description: |-
        Serializer for changing vendor type (NON_REVENUE <-> REVENUE).

        When changing to REVENUE:
        - password is required (for dashboard access)
        - revenue_model is required
        - partner_percent or fixed_amount is required based on revenue_model

        When changing to NON_REVENUE:
        - No additional fields required
        - Revenue share will be deleted
      properties:
        vendor_type:
          allOf:
          - $ref: '#/components/schemas/VendorTypeEnum'
          description: |-
            New vendor type

            * `REVENUE` - REVENUE
            * `NON_REVENUE` - NON_REVENUE
        password:
          type: string
          writeOnly: true
          nullable: true
          minLength: 8
          description: Password for dashboard access (required when changing to REVENUE)
          maxLength: 128
        revenue_model:
          nullable: true
          description: |-
            Revenue model type (required when changing to REVENUE)

            * `PERCENTAGE` - PERCENTAGE
            * `FIXED` - FIXED
          oneOf:
          - $ref: '#/components/schemas/RevenueModelEnum'
          - $ref: '#/components/schemas/NullEnum'
        partner_percent:
          type: string
          format: decimal
          pattern: ^-?\d{0,3}(?:\.\d{0,2})?$
          nullable: true
          description: Vendor's % share (required if revenue_model=PERCENTAGE)
        fixed_amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
          nullable: true
          description: Fixed monthly amount (required if revenue_model=FIXED)
        reason:
          type: string
          description: Reason for vendor type change (added to notes)
