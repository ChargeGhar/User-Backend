components:
  schemas:
    AchievementClaimData:
      type: object
      properties:
        achievement:
          $ref: '#/components/schemas/UserAchievement'
        points_awarded:
          type: integer
        new_rank:
          type: integer
          nullable: true
        total_points:
          type: integer
      required:
      - achievement
      - new_rank
      - points_awarded
      - total_points
    Action328Enum:
      enum:
      - APPROVE
      - REJECT
      type: string
      description: |-
        * `APPROVE` - APPROVE
        * `REJECT` - REJECT
    ActivateLateFeeConfigurationRequest:
      type: object
      description: Serializer for activating a late fee configuration
      properties:
        deactivate_others:
          type: boolean
          default: true
    ActiveCouponsResponse:
      type: object
      description: Response serializer for active coupons endpoint
      properties:
        success:
          type: boolean
        message:
          type: string
        data:
          type: array
          items:
            $ref: '#/components/schemas/CouponPublic'
        timestamp:
          type: string
          format: date-time
      required:
      - data
      - message
      - success
      - timestamp
    AdRequestCreateRequest:
      type: object
      description: |-
        Request serializer for creating ad request
        Used in: POST /api/user/ads/request
      properties:
        full_name:
          type: string
          minLength: 1
          description: Advertiser's full name
          maxLength: 255
        contact_number:
          type: string
          minLength: 1
          description: Contact phone number
          maxLength: 20
        media_upload_id:
          type: string
          format: uuid
          description: Media upload ID (IMAGE or VIDEO only)
      required:
      - contact_number
      - full_name
      - media_upload_id
    AdRequestDetail:
      type: object
      description: |-
        Detailed response serializer for single ad request
        Used in: POST /api/user/ads/request (response)
        Inherits from AdRequestListSerializer with same fields
      properties:
        id:
          type: string
          format: uuid
          readOnly: true
        full_name:
          type: string
          readOnly: true
        contact_number:
          type: string
          readOnly: true
        title:
          type: string
          readOnly: true
          nullable: true
        description:
          type: string
          readOnly: true
          nullable: true
        status:
          type: string
          readOnly: true
        duration_days:
          type: integer
          readOnly: true
          nullable: true
        admin_price:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          readOnly: true
          nullable: true
        submitted_at:
          type: string
          format: date-time
          readOnly: true
        reviewed_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        approved_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        paid_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        completed_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        start_date:
          type: string
          format: date
          readOnly: true
          nullable: true
        end_date:
          type: string
          format: date
          readOnly: true
          nullable: true
        rejection_reason:
          type: string
          readOnly: true
          nullable: true
        admin_notes:
          type: string
          readOnly: true
          nullable: true
        ad_content:
          type: string
          readOnly: true
        stations:
          type: string
          readOnly: true
        transaction:
