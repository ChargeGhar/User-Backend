  /api/ads/requests/{ad_id}/action:
    post:
      operationId: api_ads_requests_action_create
      description: "\n        Perform various actions on ad request:\n        \n \
        \       **APPROVE**: Approve reviewed ad (UNDER_REVIEW → PENDING_PAYMENT)\n\
        \        \n        **REJECT**: Reject ad with reason (SUBMITTED/UNDER_REVIEW\
        \ → REJECTED)\n        - Requires: rejection_reason\n        \n        **SCHEDULE**:\
        \ Schedule paid ad (PAID → SCHEDULED)\n        - Requires: start_date\n  \
        \      - Optional: end_date (auto-calculated if not provided)\n        \n\
        \        **PAUSE**: Pause running ad (RUNNING → PAUSED)\n        \n      \
        \  **RESUME**: Resume paused ad (PAUSED → RUNNING)\n        \n        **CANCEL**:\
        \ Cancel ad (Any except COMPLETED → CANCELLED)\n        - Optional: reason\n\
        \        \n        **COMPLETE**: Mark ad as completed (RUNNING → COMPLETED)\n\
        \        "
      summary: Execute Ad Action
      parameters:
      - in: path
        name: ad_id
        schema:
          type: string
        required: true
      tags:
      - Admin - Advertisements
      requestBody:
        content:
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/AdminAdActionRequest'
          application/json:
            schema:
              $ref: '#/components/schemas/AdminAdActionRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/AdminAdActionRequest'
        required: true
      security:
      - cookieAuth: []
      - basicAuth: []
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AdminAdRequestDetail'
          description: ''
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BaseResponse'
          description: ''
