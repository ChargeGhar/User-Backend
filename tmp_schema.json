          nullable: true
          description: Optional preferred points to use for wallet_points mode/When
            selected payment_mode is 'wallet_points', both wallet_amount and points_to_use
            must be provided
    RentalStartRequest:
      type: object
      description: |-
        Request serializer for starting a rental.
        Used in: POST /api/rentals/start
      properties:
        station_sn:
          type: string
          minLength: 1
          description: Station serial number where powerbank is picked up
          maxLength: 255
        package_id:
          type: string
          format: uuid
          description: Selected rental package ID
        powerbank_sn:
          type: string
          nullable: true
          description: 'Optional: Specific powerbank SN to rent'
          maxLength: 50
        payment_method_id:
          type: string
          format: uuid
          nullable: true
          description: 'Optional: Payment method ID (required if payment is needed)/When
            selected payment_mode is ''direct'' payment method ID must be provided'
        payment_mode:
          allOf:
          - $ref: '#/components/schemas/PaymentModeEnum'
          default: wallet_points
          description: |-
            Payment mode: wallet, points, wallet_points, or direct

            * `wallet` - Wallet
            * `points` - Points
            * `wallet_points` - Wallet + Points
            * `direct` - Direct Gateway Payment
        wallet_amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          nullable: true
          description: Optional preferred wallet amount for wallet_points mode/When
            selected payment_mode is 'wallet_points', both wallet_amount and points_to_use
            must be provided
        points_to_use:
          type: integer
          minimum: 0
          nullable: true
          description: Optional preferred points to use for wallet_points mode/When
