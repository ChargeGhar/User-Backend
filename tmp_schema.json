  /api/admin/points/history:
    get:
      operationId: api_admin_points_history_retrieve
      description: Get paginated points transaction history for all users with filters
        (Staff only). Use 'search' field to filter by user ID (numeric), username,
        email, or transaction description.
      summary: Points Transaction History
      parameters:
      - in: query
        name: end_date
        schema:
          type: string
          format: date-time
        description: End date for filtering
      - in: query
        name: page
        schema:
          type: integer
          minimum: 1
          default: 1
        description: Page number
      - in: query
        name: page_size
        schema:
          type: integer
          maximum: 100
          minimum: 1
          default: 20
        description: Items per page
      - in: query
        name: search
        schema:
          type: string
          minLength: 1
          maxLength: 100
        description: Search by user ID, username, email, or transaction description
      - in: query
        name: source
        schema:
          enum:
          - SIGNUP
          - REFERRAL_INVITER
          - REFERRAL_INVITEE
          - TOPUP
          - RENTAL_COMPLETE
          - TIMELY_RETURN
          - COUPON
          - RENTAL_PAYMENT
          - ADMIN_ADJUSTMENT
          type: string
          minLength: 1
        description: |-
          Filter by source

          * `SIGNUP` - SIGNUP
          * `REFERRAL_INVITER` - REFERRAL_INVITER
          * `REFERRAL_INVITEE` - REFERRAL_INVITEE
          * `TOPUP` - TOPUP
          * `RENTAL_COMPLETE` - RENTAL_COMPLETE
          * `TIMELY_RETURN` - TIMELY_RETURN
          * `COUPON` - COUPON
          * `RENTAL_PAYMENT` - RENTAL_PAYMENT
          * `ADMIN_ADJUSTMENT` - ADMIN_ADJUSTMENT
      - in: query
        name: start_date
        schema:
          type: string
          format: date-time
        description: Start date for filtering
      - in: query
        name: transaction_type
        schema:
          enum:
          - EARNED
          - SPENT
          - ADJUSTMENT
          type: string
          minLength: 1
        description: |-
          Filter by transaction type

          * `EARNED` - EARNED
          * `SPENT` - SPENT
          * `ADJUSTMENT` - ADJUSTMENT
      tags:
      - Admin - Points
      security:
      - cookieAuth: []
      - basicAuth: []
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BaseResponse'
          description: ''
